\nRange: [{HU_MIN_BRAIN}, {HU_MAX_BRAIN}] HU',\n                           fontsize=10, fontweight='bold', color=color)\n    axes[row, 1].axis('off')\n\nplt.tight_layout()\nplt.savefig(f\"{FIGURES_DIR}/hu_clipping.png\", dpi=150, bbox_inches='tight')\nplt.show()\nprint(f\"✅ Figure saved to {FIGURES_DIR}/hu_clipping.png\")\n\n# ── Clipping Impact Analysis ───────────────────────────────\nprint(\"📋 Clipping Impact Analysis\")\nprint(\"=\" * 50)\n\nfor hu, label in [(neg_hu, 'NEGATIVE'), (pos_hu, 'POSITIVE')]:\n    total         = hu.size\n    below         = (hu < HU_MIN_BRAIN).sum()\n    above         = (hu > HU_MAX_BRAIN).sum()\n    kept          = total - below - above\n\n    print(f\"\\n{label}:\")\n    print(f\"  Pixels clipped below {HU_MIN_BRAIN} HU : {below:,} ({below/total*100:.1f}%)\")\n    print(f\"  Pixels clipped above  {HU_MAX_BRAIN} HU : {above:,} ({above/total*100:.1f}%)\")\n    print(f\"  Pixels kept in range          : {kept:,} ({kept/total*100:.1f}%)\")\n\n# ── Visualization ──────────────────────────────────────────\nfig, axes = plt.subplots(1, 2, figsize=(14, 5))\nfig.suptitle('HU Distribution — Impact of Clipping', fontsize=13, fontweight='bold')\n\ncases = [\n    (neg_hu, neg_clipped, 'NEGATIVE',       '#2ecc71'),\n    (pos_hu, pos_clipped, 'POSITIVE (SAH)', '#e74c3c'),\n]\n\nfor ax, (raw, clipped, label, color) in zip(axes, cases):\n    ax.hist(raw.flatten(),     bins=80, color='#95a5a6', alpha=0.5,\n            label='Before clipping', edgecolor='none')\n    ax.hist(clipped.flatten(), bins=80, color=color,     alpha=0.7,\n            label='After clipping',  edgecolor='none')\n    ax.axvline(HU_MIN_BRAIN, color='blue',   linestyle='--',\n               linewidth=1.5, label=f'Min = {HU_MIN_BRAIN}')\n    ax.axvline(HU_MAX_BRAIN, color='orange', linestyle='--',\n               linewidth=1.5, label=f'Max = {HU_MAX_BRAIN}')\n    ax.set_title(f'{label}', fontsize=11, fontweight='bold')\n    ax.set_xlabel('HU Value')\n    ax.set_ylabel('Pixel Count')