m space\n      - BatchNorm1d stabilizes feature scale across variable CT slice densities\n      - SiLU matches EfficientNet backbone's native activation function\n    \"\"\"\n    def __init__(self):\n        super().__init__()\n        self.backbone = models.efficientnet_b3(weights='IMAGENET1K_V1')\n        in_features   = self.backbone.classifier[1].in_features  # 1536 for B3\n\n        # ── Two-stage classifier head ──────────────────────\n        self.backbone.classifier = nn.Sequential(\n            nn.Dropout(p=0.3),              # Stage 1: lighter dropout on 1536-dim space\n            nn.Linear(in_features, 512),    # Intermediate projection: 1536 → 512\n            nn.BatchNorm1d(512),            # Stabilize feature scale across CT slices\n            nn.SiLU(),                      # EfficientNet's native activation (= Swish)\n            nn.Dropout(p=0.4),              # Stage 2: heavier dropout on 512-dim space\n            nn.Linear(512, 6)               # Final output: 512 → 6 logits\n        )\n\n    def freeze_backbone(self):\n        \"\"\"\n        Phase 1: Freeze all backbone feature layers.\n        Only the classifier head remains trainable.\n        Forces model to learn CT → label mapping without\n        destroying pretrained ImageNet features.\n        \"\"\"\n        for param in self.backbone.features.parameters():\n            param.requires_grad = False\n        for param in self.backbone.classifier.parameters():\n            param.requires_grad = True\n\n    def unfreeze_top_blocks(self):\n        \"\"\"\n        Phase 2: Unfreeze top 2 MBConv blocks of EfficientNet-B3\n        (blocks 6 and 7) plus the classifier head.\n        These are the highest-level feature extractors — closest to\n        the classifier — so they benefit most from CT-specific fine-tuning.\n        Lower blocks stay frozen — their low-level edge/texture features\n        are shared between ImageNet and CT and do not need updating.\n        \"\"\"\n        # First freeze everything\n        for param in self.backbone.features.parameters():\n            param.requires_grad = False\n\n        # Then unfreeze only blocks 6 and 7 (0-indexed)\n        for param in self.backbone.features[6].parameters():\n            param.requires_grad = True\n        for param in self.backbone.features[7].parameters():\n            param.requires_grad = True\n\n        # Classifier head always trainable\n        for param in self.backbone.classifier.parameters():\n            param.requires_grad = True\n\n    def forward(self, x):\n        return self.backbone(x)              # (batch, 6) raw logits\n\n\n# ── Initialize ─────────────────────────────────────────────\nmodel = HemorrhageModel().to(DEVICE)\n\n# ── Phase 1: Freeze backbone immediately ───────────────────\nmodel.freeze_backbone()\n\n# ── Summary ────────────────────────────────────────────────\ntotal_params     = sum(p.numel() for p in model.parameters())\ntrainable_params = sum(p.numel() for p in model.parameters()\n                       if p.requires_grad)\nfrozen_params    = total_params - trainable_params\n\nprint(f\"✅ EfficientNet-B3 initialized (multi-label, Phase 1 — backbone frozen).\")\nprint(f\"\\n📋 Model Summary:\")\nprint(f\"  Total parameters     : {total_params:,}\")\nprint(f\"  Trainable parameters : {trainable_params:,}\")\nprint(f\"  Frozen parameters    : {frozen_params:,}\")\nprint(f\"  Device               : {DEVICE}\")\nprint(f\"  Input shape          : (batch, 3, 300, 300)\")\nprint(f\"  Output shape         : (batch, 6) logits\")\nprint(f\"  Labels               : {LABEL_COLS}\")\nprint(f\"\\n📋 Classifier Head Architecture:\")\nprint(f\"  Dropout(0.3) → Linear(1536→512) → BatchNorm1d(512)\")\nprint(f\"  → SiLU → Dropout(0.4) → Linear(512→6)\")\nprint(f\"\\n  Phase 1 — Only classifier head is trainable.\")\nprint(f\"  Call model.unfreeze_top_blocks() to begin Phase 2.\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Compute pos_weight for all 6 labels ────────────────────\ntotal = len(train_df)\n\nMAX_POS_WEIGHT = 50.0\n\npos_weights = torch.tensor([\n    min(2 * (total - train_df['any'].sum())              / train_df['any'].sum(),             MAX_POS_WEIGHT),\n    min((total - train_df['epidural'].sum())             / train_df['epidural'].sum(),         MAX_POS_WEIGHT),\n    min((total - train_df['intraparenchymal'].sum())     / train_df['intraparenchymal'].sum(), MAX_POS_WEIGHT),\n    min((total - train_df['intraventricular'].sum())     / train_df['intraventricular'].sum(), MAX_POS_WEIGHT),\n    min((total - train_df['subarachnoid'].sum())         / train_df['subarachnoid'].sum(),     MAX_POS_WEIGHT),\n    min((total - train_df['subdural'].sum())             / train_df['subdural'].sum(),         MAX_POS_WEIGHT),\n], dtype=torch.float32).to(DEVICE)\n\n# ── Masked Label Smoothing Loss ─────────────────────────────\nclass MaskedSmoothBCEWithLogitsLoss(nn.Module):\n    def __init__(self, pos_weight, epsilon=0.1):\n        super().__init__()\n        self.epsilon    = epsilon\n        self.pos_weight = pos_weight\n\n    def forward(self, logits, targets, mask):\n        # CHANGE: force float32 — AMP runs in float16 which overflows\n        # BCE with large pos_weights produces values that exceed float16 max\n        # Casting here ensures stable loss regardless of autocast context\n        logits  = logits.float()\n        targets = targets.float()\n        mask    = mask.float()\n\n        targets_smooth = targets * (1 - self.epsilon) + 0.5 * self.epsilon\n        bce_loss = nn.functional.binary_cross_entropy_with_logits(\n            logits,\n            targets_smooth,\n            pos_weight = self.pos_weight,\n            reduction  = 'none'\n        )\n        masked_loss     = bce_loss * mask\n        active_elements = mask.sum()\n        if active_elements == 0:\n            return torch.tensor(0.0, device=logits.device)\n        return masked_loss.sum() / active_elements\n\ncriterion = MaskedSmoothBCEWithLogitsLoss(pos_weight=pos_weights, epsilon=0.1)\n\n# ── Phase 1 Optimizer ──────────────────────────────────────\noptimizer = optim.Adam(\n    filter(lambda p: p.requires_grad, model.parameters()),\n    lr           = 3e-4,\n    weight_decay = 1e-4\n)\n\n# ── Phase 1 Scheduler ──────────────────────────────────────\nscheduler = optim.lr_scheduler.CosineAnnealingLR(\n    optimizer,\n    T_max   = 5,\n    eta_min = 1e-5\n)\n\nprint(f\"✅ Loss, optimizer and scheduler ready (Phase 1).\")\nprint(f\"\\n  pos_weights per label (capped at {MAX_POS_WEIGHT}):\")\nfor name, w in zip(LABEL_COLS, pos_weights.cpu()):\n    print(f\"    {name:<25} {w.item():.2f}\")\nprint(f\"\\n  Loss             : MaskedSmoothBCEWithLogitsLoss (ε=0.1, float32 forced)\")\nprint(f\"  Optimizer        : Adam (lr=3e-4, weight_decay=1e-4)\")\nprint(f\"  Scheduler        : CosineAnnealingLR (T_max=5, eta_min=1e-5)\")\nprint(f\"  Trainable params : {sum(p.numel() for p in model.parameters() if p.requires_grad):,}\")\nprint(f\"\\n  Phase 1 (epochs 1-5)  : backbone frozen, head trains at lr=3e-4\")\nprint(f\"  Phase 2 (epochs 6-10) : top 2 blocks unfrozen, fine-tune at lr=1e-5\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Transforms ─────────────────────────────────────────────\ntrain_transform = transforms.Compose([\n    transforms.RandomResizedCrop(\n        size      = IMAGE_SIZE,\n        scale     = (0.8, 1.0),\n        ratio     = (0.9, 1.1),\n        antialias = True\n    ),\n    transforms.RandomHorizontalFlip(p=0.5),\n    transforms.RandomVerticalFlip(p=0.2),\n    transforms.RandomRotation(degrees=15),\n    transforms.RandomAffine(\n        degrees=0, scale=(0.9, 1.1), translate=(0.05, 0.05)\n    ),\n    transforms.Normalize(mean=[0.485, 0.456, 0.406],\n                         std=[0.229, 0.224, 0.225])\n])\n\nval_transform = transforms.Compose([\n    transforms.Normalize(mean=[0.485, 0.456, 0.406],\n                         std=[0.229, 0.224, 0.225])\n])\n\n# ── RSNA Dataset ───────────────────────────────────────────\nclass HemorrhageDataset(Dataset):\n    def __init__(self, split_df, dicom_dir, transform=None):\n        self.df        = split_df.reset_index(drop=True)\n        self.dicom_dir = dicom_dir\n        self.transform = transform\n\n    def __len__(self):\n        return len(self.df)\n\n    def __getitem__(self, idx):\n        row      = self.df.iloc[idx]\n        slice_id = row['slice_id']\n        labels   = torch.tensor(row[LABEL_COLS].values.astype(np.float32))\n        mask     = torch.ones(6, dtype=torch.float32)\n\n        dicom_path = os.path.join(self.dicom_dir, f\"{slice_id}.dcm\")\n\n        try:\n            image, _     = preprocess_dicom(dicom_path)\n            image_tensor = torch.from_numpy(image)\n            if self.transform:\n                image_tensor = self.transform(image_tensor)\n        except Exception:\n            image_tensor = torch.zeros(3, IMAGE_SIZE, IMAGE_SIZE)\n            labels       = torch.zeros(6, dtype=torch.float32)\n            mask         = torch.zeros(6, dtype=torch.float32)\n\n        return image_tensor, labels, mask\n\n    def get_sample_weights(self):\n        n_pos   = self.df['any'].sum()\n        n_neg   = len(self.df) - n_pos\n        w_pos   = 1.0 / n_pos\n        w_neg   = 1.0 / n_neg\n        return self.df['any'].apply(\n            lambda l: w_pos if l == 1 else w_neg\n        ).tolist()\n\n# ── PhysioNet Dataset ──────────────────────────────────────\nclass PhysioNetDataset(Dataset):\n    def __init__(self, df, npy_dir, transform=None):\n        self.df        = df.reset_index(drop=True)\n        self.npy_dir   = npy_dir\n        self.transform = transform\n\n    def __len__(self):\n        return len(self.df)\n\n    def __getitem__(self, idx):\n        row       = self.df.iloc[idx]\n        labels    = torch.zeros(6, dtype=torch.float32)\n        labels[0] = float(row['Label'])\n        mask      = torch.zeros(6, dtype=torch.float32)\n        mask[0]   = 1.0\n\n        path = os.path.join(self.npy_dir, f\"{row['slice_id']}.npy\")\n\n        try:\n            image        = np.load(path)\n            image_tensor = torch.from_numpy(image)\n            if self.transform:\n                image_tensor = self.transform(image_tensor)\n        except Exception:\n            image_tensor = torch.zeros(3, IMAGE_SIZE, IMAGE_SIZE)\n            labels       = torch.zeros(6, dtype=torch.float32)\n            mask         = torch.zeros(6, dtype=torch.float32)\n\n        return image_tensor, labels, mask\n\n# ── Create and combine datasets ────────────────────────────\nrsna_train_dataset      = HemorrhageDataset(train_df, TRAIN_DICOM_DIR,\n                                            transform=train_transform)\nphysionet_train_dataset = PhysioNetDataset(physionet_df, SAVE_DIR,\n                                           transform=train_transform)\ncombined_dataset        = ConcatDataset([rsna_train_dataset,\n                                         physionet_train_dataset])\n\n# ── Sampler ────────────────────────────────────────────────\nrsna_weights = rsna_train_dataset.get_sample_weights() \n# Cap PhysioNet's total contribution to ~5% of each epoch\nPHYSIONET_FRACTION = 0.05\nrsna_total_weight = sum(rsna_weights)\n\n# Scale PhysioNet weights so their total mass = 5% of RSNA total\nphysionet_total_target = rsna_total_weight * (\n    PHYSIONET_FRACTION / (1 - PHYSIONET_FRACTION)\n)\nphysionet_per_sample = physionet_total_target / len(physionet_df)\n\nphysionet_weights = [physionet_per_sample] * len(physionet_df)\n\ncombined_weights = rsna_weights + physionet_weights\n\nsampler = WeightedRandomSampler(\n    weights     = combined_weights,\n    num_samples = len(combined_weights),\n    replacement = True\n)\n\n# ── DataLoaders ────────────────────────────────────────────\ntrain_loader = DataLoader(combined_dataset, batch_size=32,\n                          samp