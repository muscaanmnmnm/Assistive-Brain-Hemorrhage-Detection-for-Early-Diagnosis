h two-phase training run.\")\n    print(f\"  Phase 1: epochs 1-{PHASE1_EPOCHS} — backbone frozen, lr=3e-4\")\n    print(f\"  Phase 2: epochs {PHASE1_EPOCHS+1}-{NUM_EPOCHS} \"\n          f\"— top blocks unfrozen, lr=1e-5\")\n\n\n# ── AUC helper ─────────────────────────────────────────────\ndef compute_multilabel_auc(labels, preds):\n    labels = np.array(labels)\n    preds  = np.array(preds)\n\n    if np.isnan(preds).any() or np.isnan(labels).any():\n        print(\"  ⚠ WARNING: NaN detected in predictions — skipping AUC.\")\n        return {name: float('nan') for name in LABEL_COLS}, 0.0\n\n    per_label_auc = {}\n    valid_aucs    = []\n    for i, name in enumerate(LABEL_COLS):\n        y_true = labels[:, i]\n        y_pred = preds[:, i]\n        if len(np.unique(y_true)) > 1:\n            auc = roc_auc_score(y_true, y_pred)\n            per_label_auc[name] = auc\n            valid_aucs.append(auc)\n        else:\n            per_label_auc[name] = float('nan')\n\n    mean_auc = np.mean(valid_aucs) if valid_aucs else 0.0\n    return per_label_auc, mean_auc\n\n\n# ── Training loop ──────────────────────────────────────────\nfor epoch in range(start_epoch, NUM_EPOCHS):\n\n    # ── Phase transition at epoch 5 ────────────────────────\n    if epoch == PHASE1_EPOCHS and current_phase == 1:\n        print(f\"\\n{'='*60}\")\n        print(f\"  PHASE TRANSITION — Unfreezing top 2 blocks\")\n        print(f\"{'='*60}\")\n        model.unfreeze_top_blocks()\n        current_phase = 2\n        optimizer = optim.Adam(\n            filter(lambda p: p.requires_grad, model.parameters()),\n            lr           = 1e-5,\n            weight_decay = 1e-4\n        )\n        scheduler = optim.lr_scheduler.CosineAnnealingLR(\n            optimizer,\n            T_max   = PHASE2_EPOCHS,\n            eta_min = 1e-7\n        )\n        # FIX: reset early stopping patience at phase transition\n        # Phase 2 starts from a different loss landscape —\n        # penalizing it for Phase 1 no-improve count is unfair\n        no_improve = 0\n\n        trainable = sum(p.numel() for p in model.parameters()\n                        if p.requires_grad)\n        print(f\"  Trainable params after unfreeze : {trainable:,}\")\n        print(f\"  New optimizer : Adam (lr=1e-5, weight_decay=1e-4)\")\n        print(f\"  New scheduler : CosineAnnealingLR \"\n              f\"(T_max={PHASE2_EPOCHS}, eta_min=1e-7)\")\n        print(f\"  Early stopping patience reset to 0/{PATIENCE}\")\n\n    epoch_start  = time.time()\n    phase_label  = f\"Phase {current_phase}\"\n    current_lr   = optimizer.param_groups[0]['lr']   # FIX: log LR every epoch\n\n    print(f\"\\n{'='*60}\")\n    print(f\"  EPOCH {epoch+1}/{NUM_EPOCHS} [{phase_label}] | LR: {current_lr:.2e}\")\n    print(f\"{'='*60}\")\n\n    # ── Train ──────────────────────────────────────────────\n    model.train()\n    train_loss   = 0.0\n    train_preds  = []\n    train_labels = []\n\n    for batch_idx, (images, labels, mask) in enumerate(train_loader):\n        images = images.to(DEVICE, non_blocking=True)\n        labels = labels.float().to(DEVICE, non_blocking=True)\n        mask   = mask.float().to(DEVICE, non_blocking=True)\n\n        optimizer.zero_grad(set_to_none=True)\n\n        with autocast(device_type='cuda'):\n            logits = model(images)\n            loss   = criterion(logits, labels, mask)\n\n        scaler.scale(loss).backward()\n\n        # FIX: Gradient clipping — unscale first, then clip, then step\n        # This prevents gradient spikes during Phase 2 unfreeze\n        scaler.unscale_(optimizer)\n        torch.nn.utils.clip_grad_norm_(\n            model.parameters(),\n            max_norm = GRAD_CLIP\n        )\n\n        scaler.step(optimizer)\n        scaler.update()\n\n        train_loss += loss.item()\n\n        with torch.no_grad():\n            probs = torch.sigmoid(logits.float())\n        train_preds.append(probs.cpu().numpy())\n        train_labels.append(labels.cpu().numpy())\n\n        if (batch_idx + 1) % 2000 == 0:\n            print(f\"    Batch {batch_idx+1}/{len(train_loader)} | \"\n                  f\"Loss: {train_loss/(batch_idx+1):.4f}\")\n\n    avg_train_loss              = train_loss / len(train_loader)\n    _, train_auc = compute_multilabel_auc(\n        np.vstack(train_labels[:AUC_SAMPLE]),\n        np.vstack(train_preds[:AUC_SAMPLE])\n    )\n\n    # ── Validate ───────────────────────────────────────────\n    model.eval()\n    val_loss   = 0.0\n    val_preds  = []\n    val_labels = []\n\n    with torch.no_grad():\n        for images, labels, mask in val_loader:\n            images = images.to(DEVICE, non_blocking=True)\n            labels = labels.float().to(DEVICE, non_blocking=True)\n            mask   = mask.float().to(DEVICE, non_blocking=True)\n\n            with autocast(device_type='cuda'):\n                logits = model(images)\n                loss   = criterion(logits, labels, mask)\n\n            val_loss += loss.item()\n            probs = torch.sigmoid(logits.float())\n            val_preds.append(probs.cpu().numpy())\n            val_labels.append(labels.cpu().numpy())\n\n    avg_val_loss                    = val_loss / len(val_loader)\n    per_label_auc, mean_val_auc     = compute_multilabel_auc(\n        np.vstack(val_labels),\n        np.vstack(val_preds)\n    )\n\n    scheduler.step()\n    epoch_time = time.time() - epoch_start\n\n    # ── Epoch summary ──────────────────────────────────────\n    print(f\"\\n  📊 Epoch {epoch+1} Summary:\")\n    print(f\"     Train Loss : {avg_train_loss:.4f} | Train AUC : {train_auc:.4f}\")\n    print(f\"     Val Loss   : {avg_val_loss:.4f}   | Val AUC   : {mean_val_auc:.4f}\")\n    print(f\"     LR         : {current_lr:.2e}\")\n    print(f\"     Time       : {epoch_time/60:.1f} min\")\n    print(f\"\\n  📊 Per-Label Val AUC:\")\n    for name, auc in per_label_auc.items():\n        marker = \" ← lowest\" if auc == min(\n            v for v in per_label_auc.values()\n            if not np.isnan(v)\n        ) else \"\"\n        print(f\"     {name:<25} {auc:.4f}{marker}\")\n\n    # ── Checkpoint & Early Stopping ────────────────────────\n    history.append({\n        'epoch'       : epoch + 1,\n        'phase'       : current_phase,\n        'train_loss'  : avg_train_loss,\n        'val_loss'    : avg_val_loss,\n        'train_auc'   : train_auc,\n        'val_auc'     : mean_val_auc,\n        'lr'          : current_lr\n    })\n\n    # Always save latest checkpoint for resuming\n    torch.save({\n        'epoch'          : epoch + 1,\n        'model_state'    : model.state_dict(),\n        'optimizer_state': optimizer.state_dict(),\n        'scheduler_state': scheduler.state_dict(),\n        'best_val_auc'   : best_val_auc,\n        'history'        : history,\n        'no_improve'     : no_improve,\n        'current_phase'  : current_phase,\n    }, LATEST_CKPT)\n\n    if mean_val_auc > best_val_auc:\n        best_val_auc = mean_val_auc\n        no_improve   = 0\n        torch.save(model.state_dict(), BEST_CKPT)\n        print(f\"\\n  ✅ New best model saved — Val AUC: {best_val_auc:.4f}\")\n    else:\n        no_improve += 1\n        print(f\"\\n  ⚠ No improvement {no_improve}/{PATIENCE}\")\n\n        # FIX: actual early stopping break — was missing in previous version\n        if no_improve >= PATIENCE:\n            print(f\"\\n  🛑 Early stopping triggered at epoch {epoch+1}.\")\n            print(f\"     Best Val AUC achieved: {best_val_auc:.4f}\")\n            break\n\nprint(f\"\\n✅ Training complete.\")\nprint(f\"   Best Val AUC : {best_val_auc:.4f}\")\nprint(f\"   Best model   : {BEST_CKPT}\")","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}